{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Adaptive Model Router Profile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "version",
    "signals",
    "benchmark_tags",
    "required_capabilities",
    "validator_categories",
    "progress_metrics",
    "critical_requires_independent_verifier"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*$(?![\\s\\S])"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)$(?![\\s\\S])"
    },
    "signals": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "benchmark_tags": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "required_capabilities": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "validator_categories": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "progress_metrics": {
      "$ref": "#/$defs/nonEmptyStringArray"
    },
    "noisy_progress": {
      "type": "boolean",
      "default": false
    },
    "critical_requires_independent_verifier": {
      "type": "boolean"
    }
  },
  "$defs": {
    "nonBlankString": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!\\s)(?![\\s\\S]*\\s$)[\\s\\S]+$"
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/nonBlankString"
      }
    }
  }
}
